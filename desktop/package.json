{
  "name": "load-tube-desktop",
  "version": "1.0.0",
  "description": "load.tube - Downloader YouTube e convertitore media",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "pack": "electron-builder --dir",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac --publish=never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.3",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.loadtube.desktop",
    "productName": "load.tube",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": [
      {
        "from": "binaries/",
        "to": "binaries/"
      }
    ]
  }
}
