# Backend secrets per Fly.io
# Dopo aver deployato Vercel, aggiorna CORS_ORIGIN con l'URL di Vercel
NODE_ENV=production
PORT=4000
DATABASE_URL=file:/data/dev.db
JWT_SECRET=change-this-to-a-secure-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
CORS_ORIGIN=https://load-tube.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50
MAX_FILE_SIZE=524288000
TEMP_DIR=/app/temp
GMAIL_USER=lollino066@gmail.com
GMAIL_APP_PASSWORD=
